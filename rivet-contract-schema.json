{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rivet-contract-schema.json",
  "title": "Rivet Contract",
  "type": "object",
  "properties": {
    "types": { "type": "array", "items": { "$ref": "#/$defs/typeDefinition" } },
    "enums": { "type": "array", "items": { "$ref": "#/$defs/contractEnum" } },
    "endpoints": { "type": "array", "items": { "$ref": "#/$defs/endpointDefinition" } }
  },
  "required": ["types", "enums", "endpoints"],
  "additionalProperties": false,
  "$defs": {
    "tsType": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": { "const": "primitive" },
            "type": { "type": "string" },
            "format": { "type": "string" },
            "csharpType": { "type": "string" }
          },
          "required": ["kind", "type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "nullable" },
            "inner": { "$ref": "#/$defs/tsType" }
          },
          "required": ["kind", "inner"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "array" },
            "element": { "$ref": "#/$defs/tsType" }
          },
          "required": ["kind", "element"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "dictionary" },
            "value": { "$ref": "#/$defs/tsType" }
          },
          "required": ["kind", "value"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "stringUnion" },
            "values": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          },
          "required": ["kind", "values"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "ref" },
            "name": { "type": "string" }
          },
          "required": ["kind", "name"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "generic" },
            "name": { "type": "string" },
            "typeArgs": { "type": "array", "items": { "$ref": "#/$defs/tsType" } }
          },
          "required": ["kind", "name", "typeArgs"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "typeParam" },
            "name": { "type": "string" }
          },
          "required": ["kind", "name"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "brand" },
            "name": { "type": "string" },
            "underlying": { "$ref": "#/$defs/tsType" }
          },
          "required": ["kind", "name", "underlying"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "intUnion" },
            "values": { "type": "array", "items": { "type": "integer" }, "minItems": 1 }
          },
          "required": ["kind", "values"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "inlineObject" },
            "properties": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "$ref": "#/$defs/tsType" }
                },
                "required": ["name", "type"],
                "additionalProperties": false
              }
            }
          },
          "required": ["kind", "properties"],
          "additionalProperties": false
        }
      ]
    },
    "tsPropertyConstraints": {
      "type": "object",
      "properties": {
        "minLength": { "type": "integer" },
        "maxLength": { "type": "integer" },
        "pattern": { "type": "string" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "exclusiveMinimum": { "type": "number" },
        "exclusiveMaximum": { "type": "number" },
        "multipleOf": { "type": "number" },
        "minItems": { "type": "integer" },
        "maxItems": { "type": "integer" },
        "uniqueItems": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "tsPropertyDefinition": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/tsType" },
        "optional": { "type": "boolean" },
        "deprecated": { "type": "boolean" },
        "format": { "type": "string" },
        "defaultValue": { "type": "string" },
        "constraints": { "$ref": "#/$defs/tsPropertyConstraints" },
        "description": { "type": "string" },
        "example": { "type": "string" },
        "readOnly": { "type": "boolean" },
        "writeOnly": { "type": "boolean" }
      },
      "required": ["name", "type", "optional"],
      "additionalProperties": false
    },
    "typeDefinition": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "typeParameters": { "type": "array", "items": { "type": "string" } },
        "properties": { "type": "array", "items": { "$ref": "#/$defs/tsPropertyDefinition" } },
        "description": { "type": "string" }
      },
      "required": ["name", "typeParameters", "properties"],
      "additionalProperties": false
    },
    "contractEnum": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "values": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          },
          "required": ["name", "values"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "intValues": { "type": "array", "items": { "type": "integer" }, "minItems": 1 }
          },
          "required": ["name", "intValues"],
          "additionalProperties": false
        }
      ]
    },
    "endpointParam": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/tsType" },
        "source": { "type": "string", "enum": ["route", "body", "query", "file", "formField"] }
      },
      "required": ["name", "type", "source"],
      "additionalProperties": false
    },
    "responseType": {
      "type": "object",
      "properties": {
        "statusCode": { "type": "integer" },
        "dataType": { "$ref": "#/$defs/tsType" },
        "description": { "type": "string" }
      },
      "required": ["statusCode"],
      "additionalProperties": false
    },
    "endpointSecurity": {
      "type": "object",
      "properties": {
        "isAnonymous": { "type": "boolean" },
        "scheme": { "type": "string" }
      },
      "required": ["isAnonymous"],
      "additionalProperties": false
    },
    "endpointDefinition": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "httpMethod": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
        "routeTemplate": { "type": "string" },
        "params": { "type": "array", "items": { "$ref": "#/$defs/endpointParam" } },
        "returnType": { "$ref": "#/$defs/tsType" },
        "controllerName": { "type": "string" },
        "responses": { "type": "array", "items": { "$ref": "#/$defs/responseType" } },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "security": { "$ref": "#/$defs/endpointSecurity" },
        "fileContentType": { "type": "string" },
        "inputTypeName": { "type": "string" },
        "isFormEncoded": { "type": "boolean" }
      },
      "required": ["name", "httpMethod", "routeTemplate", "params", "controllerName", "responses"],
      "additionalProperties": false
    }
  }
}
