{
    "name": "rivet/php-reflector",
    "description": "PHP reflection utilities for Rivet contract generation",
    "type": "library",
    "license": "MIT",
    "keywords": ["rivet", "reflection", "typescript", "codegen", "dto", "contract"],
    "homepage": "https://github.com/maxanstey-meridian/rivet",
    "support": {
        "issues": "https://github.com/maxanstey-meridian/rivet/issues",
        "source": "https://github.com/maxanstey-meridian/rivet/tree/main/php-reflector"
    },
    "autoload": {
        "psr-4": {
            "Rivet\\PhpReflector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rivet\\PhpReflector\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "suggest": {
        "illuminate/routing": "Required for Laravel route adapter (^10.0|^11.0|^12.0)",
        "symfony/routing": "Required for Symfony route adapter (^6.0|^7.0)",
        "symfony/console": "Required for Symfony console command (^6.0|^7.0)"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "bin": ["bin/rivet-reflect"]
}
