{
    "name": "rivet/php-reflector",
    "description": "PHP reflection utilities for Rivet contract generation",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Rivet\\PhpReflector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rivet\\PhpReflector\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "bin": ["bin/rivet-reflect"]
}
