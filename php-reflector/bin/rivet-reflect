#!/usr/bin/env php
<?php

declare(strict_types=1);

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',       // local dev
    __DIR__ . '/../../../autoload.php',         // installed as dependency
];

$autoloaded = false;
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require $path;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Error: could not find Composer autoloader. Run 'composer install'.\n");
    exit(1);
}

$opts = getopt('', ['dir:', 'out:']);

if (!isset($opts['dir'], $opts['out'])) {
    fwrite(STDERR, "Usage: rivet-reflect --dir <path> --out <file>\n");
    exit(1);
}

exit((new \Rivet\PhpReflector\ReflectCommand())->run($opts['dir'], $opts['out']));
